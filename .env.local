# Notion Next 环境变量配置
# 从 .env.example 复制并取消注释需要的变量

# ========== 核心配置（必须）==========
# Notion 页面 ID - 你的博客数据库 ID
NOTION_PAGE_ID=23f6a82f-4a6d-801f-a39d-ec4916c6d9e4
API_BASE_URL=https://www.notion.so/api/v3

# ========== 主题与语言（可选）==========
NEXT_PUBLIC_THEME=heo
NEXT_PUBLIC_LANG=zh-CN
NEXT_PUBLIC_AUTHOR=tssj
NEXT_PUBLIC_BIO=努力生活🌻
NEXT_PUBLIC_LINK=https://xiao8867785.dpdns.org
NEXT_PUBLIC_KEYWORD=市场监测, 实时分析

# ========== 性能优化（可选）==========
# 缓存刷新间隔（秒），调大节省 Vercel 资源
NEXT_PUBLIC_REVALIDATE_SECOND=3600

# ========== 站点统计（可选）==========
NEXT_PUBLIC_ANALYTICS_BUSUANZI_ENABLE=true

# ========== 评论系统（可选）==========
# 如需开启评论，取消下面对应行的注释并填入配置
# NEXT_PUBLIC_COMMENT_ENV_ID=
# NEXT_PUBLIC_COMMENT_GISCUS_REPO=

# ========== 高级选项（按需配置）==========
# ENABLE_CACHE=true
# REVALIDATION_TOKEN=
